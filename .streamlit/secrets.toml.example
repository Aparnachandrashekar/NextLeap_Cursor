RR_GROQ_API_KEY = "your_groq_api_key_here"
RR_LLM_PROVIDER = "groq"
RR_GROQ_MODEL = "llama-3.3-70b-versatile"

# Optional: SQLite file path in the deployed app (default is data/restaurants.db, or
# /tmp/rr_restaurants.db when data is missing — see streamlit_app.py)
# RR_SQLITE_DB_PATH = "/tmp/rr_restaurants.db"

# Optional: cap how many raw HF rows to ingest on first visit.
# If omitted, Streamlit ingests the full dataset so all areas are available.
# RR_STREAMLIT_INGEST_LIMIT = "5000"
