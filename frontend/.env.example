# Copy to .env.local for local dev. On Vercel, set the same in Project → Settings → Environment Variables.
#
# Public URL of your running FastAPI app (use phase4 or backend API). Must be https in production.
# Do NOT use http://127.0.0.1:8000 in Vercel: the serverless proxy cannot reach your laptop.
BACKEND_API_URL=https://your-api.example.com
